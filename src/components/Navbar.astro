---
import { siteData } from '../data/site';
import { withBase } from '../utils/withBase';

const cvUrl = `${import.meta.env.BASE_URL}${siteData.cvPath}`;
const navItems = [
  { label: 'Home', href: withBase('/') },
  { label: 'Projects', href: withBase('/projects') },
  { label: 'Experience', href: withBase('/#experience') },
  { label: 'Education', href: withBase('/#education') }
];
---

<nav class="sticky top-0 z-50 border-b border-border bg-bg/95 backdrop-blur">
  <div class="container-page flex h-16 items-center justify-between gap-3">
    <a href={withBase('/')} class="font-mono text-xs uppercase tracking-[0.18em] text-ink">{siteData.name}</a>

    <div class="hidden items-center gap-7 lg:flex">
      {navItems.map((item) => (
        <a href={item.href} class="text-sm text-muted transition-colors hover:text-ink">{item.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href={siteData.githubUrl}
        target="_blank"
        rel="noreferrer"
        aria-label="GitHub"
        class="rounded-lg border border-transparent p-2 text-muted transition hover:border-border hover:bg-surface hover:text-ink"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true"><path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58l-.01-2.05c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.1-.75.08-.73.08-.73 1.21.09 1.85 1.25 1.85 1.25 1.08 1.84 2.82 1.31 3.5 1 .11-.79.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.9 0-1.3.47-2.37 1.24-3.2-.12-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.22a11.4 11.4 0 0 1 6 0c2.28-1.54 3.29-1.22 3.29-1.22.66 1.65.24 2.87.12 3.17.77.83 1.24 1.9 1.24 3.2 0 4.58-2.81 5.59-5.49 5.89.43.38.82 1.11.82 2.24l-.01 3.32c0 .32.21.69.82.57A12 12 0 0 0 12 .5z"/></svg>
      </a>
      <a
        href={siteData.linkedinUrl}
        target="_blank"
        rel="noreferrer"
        aria-label="LinkedIn"
        class="rounded-lg border border-transparent p-2 text-muted transition hover:border-border hover:bg-surface hover:text-ink"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.58c0-1.33-.03-3.05-1.86-3.05-1.86 0-2.14 1.45-2.14 2.95v5.68H9.35V9h3.4v1.56h.05c.47-.9 1.63-1.86 3.35-1.86 3.59 0 4.25 2.36 4.25 5.43v6.32zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77A1.77 1.77 0 0 0 0 1.77v20.46C0 23.2.8 24 1.77 24h20.46A1.77 1.77 0 0 0 24 22.23V1.77A1.77 1.77 0 0 0 22.23 0z"/></svg>
      </a>
      <a
        href={cvUrl}
        download
        class="rounded-lg border border-accent bg-accent px-3 py-2 text-xs font-semibold text-white transition hover:bg-[#121a2d] sm:px-4"
      >
        Download CV
      </a>
    </div>
  </div>

  <div class="container-page flex gap-4 overflow-x-auto border-t border-border/80 py-2 lg:hidden">
    {navItems.map((item) => (
      <a href={item.href} class="whitespace-nowrap rounded-md border border-border bg-surface px-3 py-1.5 font-mono text-[11px] uppercase tracking-wide text-muted hover:text-ink">
        {item.label}
      </a>
    ))}
  </div>
</nav>
