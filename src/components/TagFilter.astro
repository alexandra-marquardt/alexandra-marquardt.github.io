---
interface Props {
  tags: string[];
  targetId: string;
}

const { tags, targetId } = Astro.props;
---

<div class="mb-6 flex flex-wrap gap-2" data-tag-filter data-target={targetId}>
  <button
    type="button"
    data-tag="all"
    class="tag-filter-btn rounded-md border border-accent bg-accent px-3 py-1 text-xs font-semibold text-white"
  >
    All
  </button>
  {tags.map((tag) => (
    <button
      type="button"
      data-tag={tag.toLowerCase()}
      class="tag-filter-btn rounded-md border border-border bg-surface px-3 py-1 text-xs font-semibold text-muted transition hover:border-ink hover:text-ink"
    >
      {tag}
    </button>
  ))}
</div>

<script>
  const syncButtons = (container, activeTag) => {
    const buttons = container.querySelectorAll('.tag-filter-btn');
    buttons.forEach((btn) => {
      const isActive = btn.dataset.tag === activeTag;
      btn.classList.toggle('bg-accent', isActive);
      btn.classList.toggle('border-accent', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('bg-surface', !isActive);
      btn.classList.toggle('border-border', !isActive);
      btn.classList.toggle('text-muted', !isActive);
    });
  };

  document.querySelectorAll('[data-tag-filter]').forEach((container) => {
    const targetId = container.getAttribute('data-target');
    const target = targetId ? document.getElementById(targetId) : null;
    if (!target) return;

    const cards = target.querySelectorAll('[data-project-card]');

    container.querySelectorAll('.tag-filter-btn').forEach((button) => {
      button.addEventListener('click', () => {
        const selectedTag = button.dataset.tag || 'all';

        cards.forEach((card) => {
          const cardTags = (card.getAttribute('data-tags') || '').split('|').filter(Boolean);
          const shouldShow = selectedTag === 'all' || cardTags.includes(selectedTag);
          card.classList.toggle('hidden', !shouldShow);
        });

        syncButtons(container, selectedTag);
      });
    });
  });
</script>
