---
interface Props {
  title: string;
  subtitle?: string;
  id?: string;
}

const { title, subtitle, id } = Astro.props;
---

<header id={id} class="mb-7 sm:mb-10 reveal">
  <h2 class="font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">{title}</h2>
  {subtitle && <p class="mt-3 max-w-3xl text-sm text-muted sm:text-base">{subtitle}</p>}
</header>
