---
type TimelineItem = {
  title: string;
  subtitle: string;
  meta: string;
  bullets: string[];
  chips?: string[];
};

interface Props {
  items: TimelineItem[];
  variant?: 'experience' | 'education';
}

const { items } = Astro.props;
const { variant = 'experience' } = Astro.props as Props;
---

<div class="relative space-y-6 before:absolute before:bottom-0 before:left-[11px] before:top-0 before:w-px before:bg-border">
  {items.map((item) => (
    <article class="relative pl-10 reveal">
      <span
        class={`absolute left-0 top-1 h-[22px] w-[22px] rounded-full border bg-surface ${
          variant === 'experience' ? 'border-blue-500/70' : 'border-violet-500/70'
        }`}
        aria-hidden="true"
      ></span>
      <div
        class={`surface-card p-5 sm:p-6 ${
          variant === 'experience'
            ? 'bg-[linear-gradient(135deg,rgba(59,130,246,0.07)_0%,rgba(255,255,255,1)_30%)]'
            : 'bg-[linear-gradient(135deg,rgba(139,92,246,0.07)_0%,rgba(255,255,255,1)_30%)]'
        }`}
      >
        <header class="flex flex-wrap items-center justify-between gap-2">
          <h3 class="font-display text-2xl leading-tight text-ink">{item.title}</h3>
          <p
            class={`font-mono text-[11px] uppercase tracking-wide ${
              variant === 'experience' ? 'text-blue-700' : 'text-violet-700'
            }`}
          >
            {item.meta}
          </p>
        </header>
        <p class="mt-2 text-sm text-muted">{item.subtitle}</p>

        <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-muted">
          {item.bullets.map((bullet) => (
            <li>{bullet}</li>
          ))}
        </ul>

        {item.chips && item.chips.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {item.chips.map((chip) => (
              <span
                class={`rounded-md border px-2 py-1 font-mono text-[11px] ${
                  variant === 'experience'
                    ? 'border-blue-200 bg-blue-50 text-blue-700'
                    : 'border-violet-200 bg-violet-50 text-violet-700'
                }`}
              >
                {chip}
              </span>
            ))}
          </div>
        )}
      </div>
    </article>
  ))}
</div>
