---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import TagFilter from '../../components/TagFilter.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const projects = (await getCollection('projects')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const tags = [...new Set(projects.flatMap((project) => project.data.tags))].sort();
---

<BaseLayout title="Projects | Portfolio" description="All project posts with tags, demos, and source code links.">
  <Navbar />
  <main class="container-page section-spacing">
    <SectionHeader title="All Projects" subtitle="Filter by topic and open source links, demos, and write-ups." />
    <TagFilter tags={tags} targetId="all-project-grid" />
    <div id="all-project-grid" class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
    <script>
      const equalizeProjectCards = (gridId) => {
        const grid = document.getElementById(gridId);
        if (!grid) return;

        const descriptions = Array.from(grid.querySelectorAll('[data-project-description]'));
        const cards = Array.from(grid.querySelectorAll('[data-project-card]'));
        if (!descriptions.length || !cards.length) return;

        descriptions.forEach((el) => {
          el.style.minHeight = '0px';
        });
        cards.forEach((el) => {
          el.style.minHeight = '0px';
        });

        const maxDescriptionHeight = Math.max(...descriptions.map((el) => el.getBoundingClientRect().height));
        descriptions.forEach((el) => {
          el.style.minHeight = `${maxDescriptionHeight}px`;
        });

        const maxCardHeight = Math.max(...cards.map((el) => el.getBoundingClientRect().height));
        cards.forEach((el) => {
          el.style.minHeight = `${maxCardHeight}px`;
        });
      };

      const runEqualize = () => equalizeProjectCards('all-project-grid');
      runEqualize();
      window.addEventListener('resize', runEqualize);
    </script>
  </main>
  <Footer />
</BaseLayout>
