---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Timeline from '../components/Timeline.astro';
import { techGroups } from '../data/tech';
import { experience } from '../data/experience';
import { education } from '../data/education';
import { profileDetails } from '../data/profile';

const featuredProjects = (await getCollection('projects'))
  .filter((project) => project.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  //.slice(0, 6);

const experienceItems = experience.map((item) => ({
  title: item.company,
  subtitle: `${item.role} · ${item.location}`,
  meta: `${item.start} — ${item.end}`,
  bullets: item.bullets,
  chips: item.tech
}));

const educationItems = education.map((item) => ({
  title: item.degree,
  subtitle: `${item.university} · ${item.location}`,
  meta: `${item.start} — ${item.end}`,
  bullets: item.highlights,
  chips: []
}));

const personalCards = [
  { title: 'Languages', items: profileDetails.languages },
  { title: 'Scholarships', items: profileDetails.scholarships },
  { title: 'Passions', items: profileDetails.passions }
];
---

<BaseLayout>
  <Navbar />
  <main class="container-page pb-8">
    <Hero />

    <section id="projects" class="section-spacing">
      <SectionHeader
        title="Research Highlights"
        subtitle="A selection of projects spanning multimodal fusion, 3D scene understanding, and robust deployment."
      />
      <div id="featured-project-grid" class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
      <script>
        const equalizeProjectCards = (gridId) => {
          const grid = document.getElementById(gridId);
          if (!grid) return;

          const descriptions = Array.from(grid.querySelectorAll('[data-project-description]'));
          const cards = Array.from(grid.querySelectorAll('[data-project-card]'));
          if (!descriptions.length || !cards.length) return;

          descriptions.forEach((el) => {
            el.style.minHeight = '0px';
          });
          cards.forEach((el) => {
            el.style.minHeight = '0px';
          });

          const maxDescriptionHeight = Math.max(...descriptions.map((el) => el.getBoundingClientRect().height));
          descriptions.forEach((el) => {
            el.style.minHeight = `${maxDescriptionHeight}px`;
          });

          const maxCardHeight = Math.max(...cards.map((el) => el.getBoundingClientRect().height));
          cards.forEach((el) => {
            el.style.minHeight = `${maxCardHeight}px`;
          });
        };

        const runEqualize = () => equalizeProjectCards('featured-project-grid');
        runEqualize();
        window.addEventListener('resize', runEqualize);
      </script>
    </section>

    <section id="stack" class="section-spacing">
      <SectionHeader title="Tech Stack" subtitle="Core tools for research throughput and production-grade system delivery." />
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-12">
        {techGroups.map((group, idx) => (
          <article
            class={`group reveal relative overflow-hidden rounded-2xl border border-border bg-surface p-5 transition duration-300 hover:-translate-y-1 hover:shadow-card sm:p-6 ${
              idx === 0 ? 'xl:col-span-7' : idx === 1 ? 'xl:col-span-5' : idx === 2 ? 'xl:col-span-5' : 'xl:col-span-7'
            }`}
          >
            <div
              class={`pointer-events-none absolute inset-0 opacity-0 transition duration-300 group-hover:opacity-100 ${
                idx === 0
                  ? 'bg-gradient-to-br from-blue-100/80 to-transparent'
                  : idx === 1
                    ? 'bg-gradient-to-br from-indigo-100/80 to-transparent'
                    : idx === 2
                      ? 'bg-gradient-to-br from-teal-100/80 to-transparent'
                      : 'bg-gradient-to-br from-slate-100/80 to-transparent'
              }`}
            ></div>
            <div class="relative z-10">
              <div class="flex items-center justify-between gap-3">
                <div class="flex items-center gap-3">
                  <span
                    class={`rounded-lg border p-2 ${
                      idx === 0
                        ? 'border-blue-200 bg-blue-50 text-blue-700'
                        : idx === 1
                          ? 'border-indigo-200 bg-indigo-50 text-indigo-700'
                          : idx === 2
                            ? 'border-teal-200 bg-teal-50 text-teal-700'
                            : 'border-slate-200 bg-slate-50 text-slate-700'
                    }`}
                  >
                    {
                      idx === 0 ? (
                        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                          <path d="M4 12h16M12 4v16" />
                          <circle cx="12" cy="12" r="8" />
                        </svg>
                      ) : idx === 1 ? (
                        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                          <path d="M8 9l-3 3 3 3M16 9l3 3-3 3M14 6l-4 12" />
                        </svg>
                      ) : idx === 2 ? (
                        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                          <rect x="3.5" y="5" width="17" height="5" rx="1.5" />
                          <rect x="3.5" y="14" width="17" height="5" rx="1.5" />
                        </svg>
                      ) : (
                        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                          <path d="M4 16l4-4 3 3 5-5 4 4" />
                          <path d="M4 20h16" />
                        </svg>
                      )
                    }
                  </span>
                  <h3 class="text-base font-semibold text-ink">{group.title}</h3>
                </div>
              </div>
              <ul class="mt-4 flex flex-wrap gap-2 text-sm text-muted">
                {group.items.map((item) => (
                  <li
                    class={`rounded-lg border bg-bg px-3 py-1.5 transition group-hover:text-ink ${
                      idx === 0
                        ? 'border-border group-hover:border-blue-200'
                        : idx === 1
                          ? 'border-border group-hover:border-indigo-200'
                          : idx === 2
                            ? 'border-border group-hover:border-teal-200'
                            : 'border-border group-hover:border-slate-300'
                    }`}
                  >
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section-spacing">
      <div class="grid grid-cols-1 gap-10 xl:grid-cols-2 xl:gap-12">
        <div id="experience">
          <SectionHeader title="Work Experience" subtitle="Production-grade perception systems built across research and engineering teams." />
          <Timeline items={experienceItems} variant="experience" />
        </div>

        <div id="education">
          <SectionHeader title="Education" subtitle="Academic foundation in robotics, vision, and machine learning." />
          <Timeline items={educationItems} variant="education" />
        </div>
      </div>
    </section>

    <section class="section-spacing">
      <SectionHeader title="Personal" subtitle="Languages, scholarships, and interests." />
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-12">
        {personalCards.map((card, idx) => (
          <article
            class={`group reveal relative overflow-hidden rounded-2xl border border-border bg-surface p-5 transition duration-300 hover:-translate-y-1 hover:shadow-card sm:p-6 ${
              idx === 0 ? 'xl:col-span-5' : idx === 1 ? 'xl:col-span-4' : 'xl:col-span-3'
            }`}
          >
            <div
              class={`pointer-events-none absolute inset-0 opacity-0 transition duration-300 group-hover:opacity-100 ${
                idx === 0
                  ? 'bg-gradient-to-tr from-indigo-100/75 to-transparent'
                  : idx === 1
                    ? 'bg-gradient-to-tr from-amber-100/70 to-transparent'
                    : 'bg-gradient-to-tr from-rose-100/70 to-transparent'
              }`}
            ></div>
            <div class="relative z-10">
              <div class="flex items-center gap-3">
                <span
                  class={`rounded-lg border p-2 ${
                    idx === 0
                      ? 'border-indigo-200 bg-indigo-50 text-indigo-700'
                      : idx === 1
                        ? 'border-amber-200 bg-amber-50 text-amber-700'
                        : 'border-rose-200 bg-rose-50 text-rose-700'
                  }`}
                >
                  {
                    idx === 0 ? (
                      <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M4 7h10M4 12h16M4 17h9" />
                      </svg>
                    ) : idx === 1 ? (
                      <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M8 12l2.5 2.5L16 9" />
                        <rect x="4" y="4" width="16" height="16" rx="2.5" />
                      </svg>
                    ) : (
                      <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 21s-7-4.3-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 11c0 5.7-7 10-7 10Z" />
                      </svg>
                    )
                  }
                </span>
                <h3 class="text-base font-semibold text-ink">{card.title}</h3>
              </div>
              <ul class="mt-4 flex flex-wrap gap-2 text-sm text-muted">
                {card.items.map((item) => (
                  <li
                    class={`rounded-lg border bg-bg px-3 py-1.5 transition group-hover:text-ink ${
                      idx === 0
                        ? 'border-border group-hover:border-indigo-200'
                        : idx === 1
                          ? 'border-border group-hover:border-amber-200'
                          : 'border-border group-hover:border-rose-200'
                    }`}
                  >
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
